# Automation Glow — Onboarding Service Environment Variables
# Copy this file to .env and fill in the values

# Notion
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google (Service Account JSON — paste the full JSON as a single line)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}

# Gmail SMTP (App Password — generate at myaccount.google.com/apppasswords)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# GHL (already pre-filled in code but can override here)
GHL_API_KEY=pit-2e377694-9c26-4726-ba33-4e8ac0128c01

# Links to insert in welcome email
CALENDLY_LINK=https://calendly.com/your-link
META_GUIDE_LINK=https://your-video-guide-link.com
